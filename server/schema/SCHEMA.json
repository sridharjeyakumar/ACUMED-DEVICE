{
  "database": "ACUMED_DEVICES",
  "version": "1.0.0",
  "lastUpdated": "2026-01-27",
  "collections": [
    {
      "name": "menumasters",
      "description": "Defines all menu items available in the system",
      "fields": [
        {
          "name": "menu_id",
          "type": "String",
          "constraints": {
            "required": true,
            "unique": true,
            "maxLength": 3,
            "primaryKey": true
          },
          "description": "Char(3) - Primary Key"
        },
        {
          "name": "menu_desc",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 100
          },
          "description": "Char(100) - Menu description"
        },
        {
          "name": "active",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Whether menu is active"
        },
        {
          "name": "last_modified_user_id",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 5
          },
          "description": "Char(5) - Last modified user ID"
        },
        {
          "name": "last_modified_date_time",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Last modified date and time"
        },
        {
          "name": "createdAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated creation timestamp"
        },
        {
          "name": "updatedAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated update timestamp"
        }
      ],
      "indexes": [
        {
          "fields": ["menu_id"],
          "unique": true
        }
      ]
    },
    {
