          },
          "description": "Char(3) - Primary Key"
        },
        {
          "name": "roll_description",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 50
          },
          "description": "Char(50) - Role description"
        },
        {
          "name": "remarks",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 100
          },
          "description": "Char(100) - Additional notes"
        },
        {
          "name": "active",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Whether role is active"
        },
        {
          "name": "last_modified_user_id",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 5
          },
          "description": "Char(5) - Last modified user ID"
        },
        {
          "name": "last_modified_date_time",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Last modified date and time"
        },
        {
          "name": "createdAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated creation timestamp"
        },
        {
          "name": "updatedAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated update timestamp"
        }
      ],
      "indexes": [
        {
          "fields": ["roll_id"],
          "unique": true
        }
      ]
    },
    {
      "name": "menuaccessmasters",
      "description": "Defines which roles have access to which menu items and what actions they can perform",
      "fields": [
        {
          "name": "rold_id",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 3,
            "foreignKey": "RoleMaster.roll_id"
          },
          "description": "Char(3) - Foreign Key to RoleMaster"
        },
        {
          "name": "menu_id",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 3,
            "foreignKey": "MenuMaster.menu_id"
          },
          "description": "Char(3) - Foreign Key to MenuMaster"
        },
        {
          "name": "access",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - General access permission"
        },
        {
          "name": "can_add",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Permission to add records"
        },
        {
          "name": "can_edit",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Permission to edit records"
        },
        {
          "name": "can_view",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Permission to view records"
        },
        {
          "name": "can_cancel",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Permission to cancel operations"
        },
        {
          "name": "last_modified_user_id",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 5
          },
          "description": "Char(5) - Last modified user ID"
        },
        {
          "name": "last_modified_date_time",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Last modified date and time"
        },
        {
          "name": "createdAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated creation timestamp"
        },
        {
          "name": "updatedAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated update timestamp"
        }
      ],
      "indexes": [
        {
          "fields": ["rold_id", "menu_id"],
          "unique": true
        }
      ]
    },
    {
      "name": "usermasters",
      "description": "Stores user account information and credentials",
      "fields": [
        {
          "name": "user_id",
          "type": "String",
          "constraints": {
            "required": true,
            "unique": true,
            "maxLength": 10,
            "primaryKey": true
          },
          "description": "Char(10) - Primary Key"
        },
        {
          "name": "employee_id",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 5
          },
          "description": "Char(5) - Foreign Key (default: same as user_id)"
        },
        {
          "name": "hash_password",
          "type": "String",
          "constraints": {
            "required": true
          },
          "description": "Hash - Bcrypt hashed password"
        },
        {
          "name": "role_id",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 3,
            "foreignKey": "RoleMaster.roll_id"
          },
          "description": "Char(3) - Foreign Key to RoleMaster"
        },
        {
          "name": "Date_password_changed_date",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Password changed date"
        },
        {
          "name": "Date_password_expiry_date",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Password expiry date"
        },
        {
          "name": "N_password_expiry_days",
          "type": "Number",
          "constraints": {
            "required": false,
            "min": 0,
            "max": 999
          },
          "description": "N(3) - Password expiry days"
        },
        {
          "name": "Date_last_login_date",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Last login date"
        },
        {
          "name": "Time_last_login_time",
          "type": "String",
          "constraints": {
            "required": false
          },
          "description": "Time - Last login time"
        },
        {
          "name": "active",
          "type": "Boolean",
          "constraints": {
            "required": true,
            "default": true
          },
          "description": "Boolean - Whether user account is active"
        },
        {
          "name": "last_modified_user_id",
          "type": "String",
          "constraints": {
            "required": false,
            "maxLength": 5
          },
          "description": "Char(5) - Last modified user ID"
        },
        {
          "name": "last_modified_date_time",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Last modified date and time"
        },
        {
          "name": "createdAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated creation timestamp"
        },
        {
          "name": "updatedAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated update timestamp"
        }
      ],
      "indexes": [
        {
          "fields": ["user_id"],
          "unique": true
        },
        {
          "fields": ["employee_id"]
        }
      ]
    },
    {
      "name": "userloginhistories",
      "description": "Records user login and logout events. An entry is created whenever a user logs in or logs out.",
      "fields": [
        {
          "name": "user_id",
          "type": "String",
          "constraints": {
            "required": true,
            "maxLength": 10,
            "foreignKey": "UserMaster.user_id"
          },
          "description": "Char(10) - Foreign Key to UserMaster"
        },
        {
          "name": "Date_login_Date",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Login date"
        },
        {
          "name": "Time_login_Time",
          "type": "String",
          "constraints": {
            "required": false
          },
          "description": "Time - Login time"
        },
        {
          "name": "Date_Logout_Date",
          "type": "Date",
          "constraints": {
            "required": false
          },
          "description": "Date - Logout date"
        },
        {
          "name": "Time_Logout_Time",
          "type": "String",
          "constraints": {
            "required": false
          },
          "description": "Time - Logout time"
        },
        {
          "name": "createdAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated creation timestamp"
        },
        {
          "name": "updatedAt",
          "type": "Date",
          "constraints": {
            "autoGenerated": true
          },
          "description": "Auto-generated update timestamp"
        }
      ],
      "indexes": [
        {
          "fields": ["user_id"]
        },
        {
          "fields": ["Date_login_Date"]
        }
      ]
