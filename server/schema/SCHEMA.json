  "relationships": [
    {
      "from": "MenuAccessMaster",
      "fromField": "rold_id",
      "to": "RoleMaster",
      "toField": "roll_id",
      "type": "many-to-one"
    },
    {
      "from": "MenuAccessMaster",
      "fromField": "menu_id",
      "to": "MenuMaster",
      "toField": "menu_id",
      "type": "many-to-one"
    },
    {
      "from": "UserMaster",
      "fromField": "role_id",
      "to": "RoleMaster",
      "toField": "roll_id",
      "type": "many-to-one"
    },
    {
      "from": "UserLoginHistory",
      "fromField": "user_id",
      "to": "UserMaster",
      "toField": "user_id",
      "type": "many-to-one"
    }
  ]
